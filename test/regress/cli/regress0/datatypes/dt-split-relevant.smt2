; COMMAND-LINE: --dt-split-relevant
; EXPECT: unsat
(set-logic ALL)
(declare-datatypes ((Color 0)) (((red) (green) (blue))))
(declare-datatypes ((Unit 0)) (((mkUnit))))
(declare-datatypes ((Box 0)) (((mkBox (elem Unit)))))
(declare-fun c () Color)
(declare-fun f (Color) Int)
(declare-fun b1 () Box)
(declare-fun b2 () Box)
(assert (or (distinct b1 b2)
            (and (distinct (f red) (f c))
                 (distinct (f green) (f c))
                 (distinct (f blue) (f c)))))
(check-sat)
